OPENAI_API_KEY=""
FILE_NAME=""
FOLDER_NAME="files"
VECTOR_STORE_NAME=""
ASSISTANT_NAME="Schedule Assistant"
OPENAI_MODEL="gpt-4o-mini-2024-07-18"
OPENAI_TEMPERATURE=0.3
MAX_RUNS=5
POLL_INTERVAL_MS=2000
TEST_USER_MESSAGE="Привіт, у 1 речені скажи хто ти і що можеш зробити. Наведи приклади запитів до тебе."
